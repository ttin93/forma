# ── Database ─────────────────────────────────────────────────────────────────
# Local Docker:   postgresql://forma:forma_dev@localhost:5432/forma
# Supabase direct: postgresql://postgres:[pass]@db.[ref].supabase.co:5432/postgres
# Supabase pooler: postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://forma:forma_dev@localhost:5432/forma

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CDN_HOST=cdn.forma.studio

# ── Lemon Squeezy (payments) ──────────────────────────────────────────────────
# Get from app.lemonsqueezy.com → Settings → API
LEMONSQUEEZY_API_KEY=
# Get from app.lemonsqueezy.com → Settings → Webhooks → [your webhook] → Signing secret
LEMONSQUEEZY_WEBHOOK_SECRET=
# Get from app.lemonsqueezy.com → Stores → [your store] → ID
LEMONSQUEEZY_STORE_ID=
# Get from app.lemonsqueezy.com → Products → [Growth plan] → Variants → ID
LEMONSQUEEZY_VARIANT_ID=

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@forma.studio

# ── Inngest (background jobs) ─────────────────────────────────────────────────
# Leave empty in local dev — Inngest dev server handles this
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Cloudflare R2 (file storage / PDF) ───────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=forma-assets
R2_PUBLIC_URL=https://assets.forma.studio
